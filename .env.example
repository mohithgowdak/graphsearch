# Copy to .env and adjust. Everything below is optional — the defaults run fully offline.

# Pipeline backends
# GRAPHSEARCH_EMBEDDINGS=hash        # hash (offline) | local (offline, semantic) | openai
# GRAPHSEARCH_LLM=extractive         # extractive (offline) | openai | anthropic

# Provider keys (required only for the matching backend)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Model overrides
# GRAPHSEARCH_LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# GRAPHSEARCH_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# GRAPHSEARCH_OPENAI_MODEL=gpt-4o-mini
# GRAPHSEARCH_ANTHROPIC_MODEL=claude-sonnet-5

# Storage & retrieval
# GRAPHSEARCH_DATABASE_PATH=graphsearch.db
# GRAPHSEARCH_CHUNK_SIZE=800
# GRAPHSEARCH_CHUNK_OVERLAP=100
# GRAPHSEARCH_DEFAULT_TOP_K=4

# Server
# GRAPHSEARCH_HOST=0.0.0.0
# GRAPHSEARCH_PORT=8000
