{
  "name": "@graphsearch/client",
  "version": "0.1.0",
  "description": "Typed TypeScript client for the GraphSearch GraphQL API, generated from the live schema with GraphQL Code Generator.",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "license": "MIT",
  "scripts": {
    "codegen": "graphql-codegen --config codegen.ts",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "graphql": "^16.9.0",
    "graphql-request": "^7.1.2"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.3",
    "@graphql-codegen/typescript": "^4.1.0",
    "@graphql-codegen/typescript-operations": "^4.3.1",
    "@graphql-codegen/typescript-graphql-request": "^6.2.0",
    "typescript": "^5.6.3"
  }
}
